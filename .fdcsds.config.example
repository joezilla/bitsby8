{
  "// Comment": "Example FDC+ Serial Drive Server Configuration File",
  "// Instructions": "Copy this file to .fdcsds.config or .config/fdcsds.json and customize",

  "// Serial port for FDC+ controller (required)": "",
  "port": "/dev/ttyUSB0",
  "baud": 230400,

  "// Disk images to mount on startup": "",
  "// Use null for empty drives": "",
  "drive0": "disks/cpm22.dsk",
  "drive1": "disks/games.dsk",
  "drive2": null,
  "drive3": null,

  "// Read-only drives (array of drive numbers 0-3)": "",
  "// Protect drives from accidental writes": "",
  "readonly": [0],

  "// Display options": "",
  "verbose": false,
  "debug": false,

  "// Web interface configuration": "",
  "web": true,
  "webPort": 3000,
  "webHost": "localhost",

  "// Terminal serial port (optional second serial port)": "",
  "// For VT102 terminal emulation via web interface": "",
  "terminalPort": "/dev/ttyUSB1",
  "terminalBaud": 9600,
  "terminalAutoconnect": false,

  "// GPIO LED status indicators (Raspberry Pi only)": "",
  "// Enable hardware status LEDs on GPIO pins": "",
  "// Set enabled to false to disable, or remove this section entirely": "",
  "gpioLeds": {
    "enabled": false,
    "blinkDuration": 100,
    "activeLow": false,

    "// Drive 0 status LEDs (BCM pin numbers)": "",
    "drive0": {
      "enable": 17,
      "headLoad": 27,
      "readOnly": 22
    },

    "// Drive 1 status LEDs": "",
    "drive1": {
      "enable": 23,
      "headLoad": 24,
      "readOnly": 25
    },

    "// Drive 2 status LEDs": "",
    "drive2": {
      "enable": 5,
      "headLoad": 6,
      "readOnly": 13
    },

    "// Drive 3 status LEDs": "",
    "drive3": {
      "enable": 19,
      "headLoad": 26,
      "readOnly": 12
    },

    "// Terminal status LEDs": "",
    "terminal": {
      "rx": 16,
      "tx": 20,
      "connected": 21
    }
  }
}
