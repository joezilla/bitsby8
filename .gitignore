# Build output
dist/
/*.js
!/create-boot-disk.js
/*.js.map

# Debian build artifacts (Makefile collects `make deb` output here)
/build/

# Generated at build time by the Makefile; loaded at runtime so
# /api/status can report the actual deployed build/commit/timestamp.
/build-info.json

# Dependencies
node_modules/
node_modules_back/

# Configuration files (personal settings)
.fdcsds.config
.config/fdcsds.json
fdcsds.config.json
*.config
!*.config.example

# Disk images (can be large)
disks/*.dsk
disks/*.img
disks/*.ima
.deps/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Test coverage
coverage/

# Environment variables
.env
.env.local
.env.*.local

# Local SQLite database
fdcplus.db
fdcplus.db-journal
fdcplus.db-wal
fdcplus.db-shm

# BMAD / Claude tooling (local-only)
_bmad/
_bmad-output/
.claude/

# Dev scratch
cassettes/
asm/
killthebit.txt
protocol.txt

# KiCad generated artifacts (keep source .kicad_*, ignore outputs)
kicad/*.gbr
kicad/*.gbrjob
kicad/*-backups/
kicad/fp-info-cache
kicad/done1.tgz
kicad/panel.png
