{
  "name": "fds-ts",
  "version": "2.0.0",
  "description": "FDC+ Serial Drive Server in TypeScript",
  "main": "dist/index.js",
  "bin": {
    "fdcsds": "./dist/index.js"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc",
    "build:web": "next build ./web",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:web": "next dev ./web",
    "start:web": "next start ./web",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "serial",
    "altair",
    "fdc",
    "disk-server",
    "vintage-computing"
  ],
  "author": "Joe Toppe (TypeScript version)",
  "license": "GPL-3.0",
  "dependencies": {
    "better-sqlite3": "^12.4.5",
    "blessed": "^0.1.81",
    "commander": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "multer": "^1.4.5-lts.1",
    "next": "^14.2.3",
    "onoff": "^6.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serialport": "^12.0.0",
    "socket.io": "^4.6.0",
    "socket.io-client": "^4.6.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/blessed": "^0.1.25",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
