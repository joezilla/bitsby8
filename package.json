{
  "name": "fds-ts",
  "version": "2.0.1",
  "description": "FDC+ Serial Drive Server in TypeScript",
  "main": "dist/index.js",
  "bin": {
    "fdcsds": "./dist/index.js",
    "create-boot-disk": "./create-boot-disk.js"
  },
  "scripts": {
    "build": "tsc && pnpm run docs",
    "build:all": "pnpm run build && pnpm --filter fdcplus-frontend build",
    "docs": "ts-node scripts/generate-openapi.ts",
    "docs:check": "ts-node scripts/generate-openapi.ts --check",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:all": "concurrently -n backend,frontend -c blue,magenta \"pnpm run dev\" \"pnpm --filter fdcplus-frontend dev\"",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: no ESLint configured (see cleanup-epic; project-context requires discussion before introducing a linter)' && exit 0",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run docs:check && pnpm run test && pnpm --filter fdcplus-frontend check",
    "clean": "rm -rf dist coverage frontend/dist"
  },
  "keywords": [
    "serial",
    "altair",
    "fdc",
    "disk-server",
    "vintage-computing"
  ],
  "author": "Joe Toppe (TypeScript version)",
  "license": "GPL-3.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/multer": "^2.0.0",
    "@types/play-sound": "^1.1.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "blessed": "^0.1.81",
    "commander": "^11.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "multer": "^2.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "play-sound": "^1.1.6",
    "serialport": "^12.0.0",
    "socket.io": "^4.6.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "onoff": "^6.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/blessed": "^0.1.25",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "@types/pino": "^7.0.4",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "concurrently": "^9.2.1",
    "jest": "^29.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.2.2",
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
