# Do not auto-download the version pinned in package.json `packageManager`.
# The Raspberry Pi builder runs Node 20 and cannot execute pnpm >= 11, which
# requires the Node 22 `node:sqlite` builtin. Let each host use whatever pnpm
# it has installed (must be >= 10.x for lockfile compatibility).
manage-package-manager-versions=false

# Don't block on a TTY prompt when pnpm wants to purge node_modules that were
# populated by a different pnpm major (e.g. after a version swap on the Pi).
confirm-modules-purge=false
