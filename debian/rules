#!/usr/bin/make -f
# -*- makefile -*-

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

%:
	dh $@

override_dh_auto_build:
	# Prefer whatever pnpm is on PATH (typically from `npm install -g
	# pnpm@10` on hosts where the corepack shim is broken). Fall back
	# to corepack only when pnpm isn't found — and even then don't fail
	# the whole build if corepack can't write /usr/bin under an
	# unprivileged builder.
	@command -v pnpm >/dev/null 2>&1 || corepack enable pnpm || true
	# Install with --config.node-linker=hoisted so node_modules is a
	# truly flat, npm-like tree — every package as a real directory
	# directly under node_modules/<name>/, no symlinks, no .pnpm/
	# indirection. This is what makes the shipped tree portable to
	# /usr/lib/bitsby8/node_modules/ where systemd-launched node can
	# resolve modules without pnpm-specific layout knowledge.
	# (--shamefully-hoist alone does NOT achieve this; it only hoists
	# transitives to top level within pnpm's still-symlinked layout,
	# leaving package directories empty post-copy.)
	#
	# Remove any existing node_modules FIRST. A prior `make build` (or a
	# -nc rebuild) leaves pnpm's default *symlinked* layout in place, and
	# a subsequent hoisted install over a lockfile-satisfied tree is a
	# no-op — pnpm won't re-lay-out the directory just because
	# node-linker changed. The stale symlinks then ship in the .deb and
	# dangle on the target (Cannot find module 'cookie-parser'). Starting
	# clean guarantees a real hoisted tree every build.
	rm -rf node_modules
	pnpm install --frozen-lockfile --config.node-linker=hoisted
	# Verify the install produced REAL, populated package directories for
	# every production dependency — not symlinks into .pnpm/ (which
	# `test -f` would follow and falsely pass) and not empty dirs. This
	# is the "ships broken, crash-loops on the Pi" class of bug; make it
	# a hard build failure instead of a runtime surprise.
	@node -e "const d=require('./package.json').dependencies||{};process.stdout.write(Object.keys(d).join('\n'))" \
		| while IFS= read -r pkg; do \
			if [ -L "node_modules/$$pkg" ] || [ ! -f "node_modules/$$pkg/package.json" ]; then \
				echo "ERROR: node_modules/$$pkg is missing, empty, or a symlink after install — node-linker=hoisted did not produce a flat tree"; \
				exit 1; \
			fi; \
		done
	# Compile backend TypeScript and (re)generate openapi.json at repo root.
	pnpm run build
	# Build the Svelte frontend SPA → frontend/dist/.
	pnpm --filter bitsby8-frontend build
	# NOTE: `pnpm prune --prod` is intentionally omitted. It misbehaves
	# on the hoisted layout (leaves dirs but strips contents). The deb
	# ships devDependencies too — larger but functional. To trim size
	# later, switch to `pnpm deploy --prod` which is purpose-built for
	# this and handles the layout end-to-end.

override_dh_auto_test:
	# Skip tests during package build (tests can be run separately).
	@echo "Skipping tests during package build"

override_dh_auto_clean:
	# Clean build artifacts from both trees.
	rm -rf dist node_modules frontend/dist frontend/node_modules
	dh_auto_clean

override_dh_auto_install:
	# Install application files to /usr/lib/bitsby8
	mkdir -p debian/bitsby8/usr/lib/bitsby8
	cp -r dist debian/bitsby8/usr/lib/bitsby8/
	mkdir -p debian/bitsby8/usr/lib/bitsby8/frontend
	cp -r frontend/dist debian/bitsby8/usr/lib/bitsby8/frontend/dist
	# Remove the workspace symlink before copying node_modules — frontend/
	# itself isn't shipped (the SPA is already built into frontend/dist/),
	# so the symlink would dangle and confuse anything that walks the tree.
	rm -f node_modules/bitsby8-frontend
	# With --shamefully-hoist (above) node_modules is a flat npm-like tree,
	# but we still use cp -a to preserve any remaining symlinks (the .pnpm/
	# directory is mostly empty in hoisted mode but may still exist).
	cp -a node_modules debian/bitsby8/usr/lib/bitsby8/
	cp package.json debian/bitsby8/usr/lib/bitsby8/
	cp pnpm-lock.yaml debian/bitsby8/usr/lib/bitsby8/
	# Ship the committed OpenAPI spec at the install root for any external
	# tooling that wants to read it without hitting /api/docs at runtime.
	cp openapi.json debian/bitsby8/usr/lib/bitsby8/ || true
	# build-info.json is generated by the Makefile before the build; the
	# runtime loads it to surface the git-derived version, commit, and
	# build timestamp via /api/status.
	cp build-info.json debian/bitsby8/usr/lib/bitsby8/ || true

	# Create symlink for binary
	mkdir -p debian/bitsby8/usr/bin
	ln -sf /usr/lib/bitsby8/dist/index.js debian/bitsby8/usr/bin/bitsby8
	# Backward-compatibility alias: operators (and the README's MCP config)
	# still invoke `fdcsds`. Keep it pointing at the same entry point.
	ln -sf /usr/lib/bitsby8/dist/index.js debian/bitsby8/usr/bin/fdcsds

	# Install configuration files
	mkdir -p debian/bitsby8/etc/bitsby8
	cp .bitsby8.config.example debian/bitsby8/etc/bitsby8/bitsby8.config.example
	# Ship the default baseline config as a dpkg conffile. The daemon
	# reads this at startup; UI-driven changes are persisted separately
	# to /var/lib/bitsby8/bitsby8.overrides.json and layered on top.
	cp debian/bitsby8.config.json debian/bitsby8/etc/bitsby8/bitsby8.config.json

	# Install sample disk images
	mkdir -p debian/bitsby8/usr/share/bitsby8/disks
	if [ -d disks ]; then \
		cp -r disks/* debian/bitsby8/usr/share/bitsby8/disks/ || true; \
	fi

	# Install documentation
	mkdir -p debian/bitsby8/usr/share/doc/bitsby8
	cp README.md debian/bitsby8/usr/share/doc/bitsby8/
	cp CONTRIBUTING.md debian/bitsby8/usr/share/doc/bitsby8/ || true
	cp docs/WEB-INTERFACE.md debian/bitsby8/usr/share/doc/bitsby8/ || true
	cp docs/LAUNCHER.md debian/bitsby8/usr/share/doc/bitsby8/ || true
	cp docs/TROUBLESHOOTING.md debian/bitsby8/usr/share/doc/bitsby8/ || true
	cp AUTHORS debian/bitsby8/usr/share/doc/bitsby8/ || true

	# NOTE: runtime directories (/var/lib/bitsby8, /var/log/bitsby8) are
	# deliberately NOT shipped in the package. postinst creates and chowns
	# them at configure time. Keeping them out of the payload is what lets
	# the fdcsds→bitsby8 data migration `mv` the legacy dir into place —
	# a shipped empty skeleton would make the target already exist and
	# strand the operator's data at the old path.

	# Install systemd service file
	mkdir -p debian/bitsby8/usr/lib/systemd/system
	cp debian/bitsby8.service debian/bitsby8/usr/lib/systemd/system/

	# Install default environment file
	mkdir -p debian/bitsby8/etc/default
	cp debian/bitsby8.default debian/bitsby8/etc/default/bitsby8

override_dh_fixperms:
	dh_fixperms
	# Make the main script executable
	chmod +x debian/bitsby8/usr/lib/bitsby8/dist/index.js

override_dh_installsystemd:
	dh_installsystemd --name=bitsby8 --no-enable --no-start
