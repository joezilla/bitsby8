#!/usr/bin/make -f
# -*- makefile -*-

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

%:
	dh $@

override_dh_auto_build:
	# Prefer whatever pnpm is on PATH (typically from `npm install -g
	# pnpm@10` on hosts where the corepack shim is broken). Fall back
	# to corepack only when pnpm isn't found — and even then don't fail
	# the whole build if corepack can't write /usr/bin under an
	# unprivileged builder.
	@command -v pnpm >/dev/null 2>&1 || corepack enable pnpm || true
	# Install with --config.node-linker=hoisted so node_modules is a
	# truly flat, npm-like tree — every package as a real directory
	# directly under node_modules/<name>/, no symlinks, no .pnpm/
	# indirection. This is what makes the shipped tree portable to
	# /usr/lib/fdcsds/node_modules/ where systemd-launched node can
	# resolve modules without pnpm-specific layout knowledge.
	# (--shamefully-hoist alone does NOT achieve this; it only hoists
	# transitives to top level within pnpm's still-symlinked layout,
	# leaving package directories empty post-copy.)
	pnpm install --frozen-lockfile --config.node-linker=hoisted
	# Verify the install actually produced populated package directories
	# before we waste cycles building. Catches future regressions of the
	# "empty serialport/ dir" class of bug immediately.
	@test -f node_modules/serialport/package.json || \
		(echo "ERROR: node_modules/serialport/ is empty after install — node-linker=hoisted not applied" && exit 1)
	@test -f node_modules/@serialport/bindings-cpp/package.json || \
		(echo "ERROR: node_modules/@serialport/bindings-cpp/ missing after install" && exit 1)
	# Compile backend TypeScript and (re)generate openapi.json at repo root.
	pnpm run build
	# Build the Svelte frontend SPA → frontend/dist/.
	pnpm --filter fdcplus-frontend build
	# NOTE: `pnpm prune --prod` is intentionally omitted. It misbehaves
	# on the hoisted layout (leaves dirs but strips contents). The deb
	# ships devDependencies too — larger but functional. To trim size
	# later, switch to `pnpm deploy --prod` which is purpose-built for
	# this and handles the layout end-to-end.

override_dh_auto_test:
	# Skip tests during package build (tests can be run separately).
	@echo "Skipping tests during package build"

override_dh_auto_clean:
	# Clean build artifacts from both trees.
	rm -rf dist node_modules frontend/dist frontend/node_modules
	dh_auto_clean

override_dh_auto_install:
	# Install application files to /usr/lib/fdcsds
	mkdir -p debian/fdcsds/usr/lib/fdcsds
	cp -r dist debian/fdcsds/usr/lib/fdcsds/
	mkdir -p debian/fdcsds/usr/lib/fdcsds/frontend
	cp -r frontend/dist debian/fdcsds/usr/lib/fdcsds/frontend/dist
	# Remove the workspace symlink before copying node_modules — frontend/
	# itself isn't shipped (the SPA is already built into frontend/dist/),
	# so the symlink would dangle and confuse anything that walks the tree.
	rm -f node_modules/fdcplus-frontend
	# With --shamefully-hoist (above) node_modules is a flat npm-like tree,
	# but we still use cp -a to preserve any remaining symlinks (the .pnpm/
	# directory is mostly empty in hoisted mode but may still exist).
	cp -a node_modules debian/fdcsds/usr/lib/fdcsds/
	cp package.json debian/fdcsds/usr/lib/fdcsds/
	cp pnpm-lock.yaml debian/fdcsds/usr/lib/fdcsds/
	# Ship the committed OpenAPI spec at the install root for any external
	# tooling that wants to read it without hitting /api/docs at runtime.
	cp openapi.json debian/fdcsds/usr/lib/fdcsds/ || true
	# build-info.json is generated by the Makefile before the build; the
	# runtime loads it to surface the git-derived version, commit, and
	# build timestamp via /api/status.
	cp build-info.json debian/fdcsds/usr/lib/fdcsds/ || true

	# Create symlink for binary
	mkdir -p debian/fdcsds/usr/bin
	ln -sf /usr/lib/fdcsds/dist/index.js debian/fdcsds/usr/bin/fdcsds

	# Install configuration files
	mkdir -p debian/fdcsds/etc/fdcsds
	cp .fdcsds.config.example debian/fdcsds/etc/fdcsds/fdcsds.config.example
	# Ship the default baseline config as a dpkg conffile. The daemon
	# reads this at startup; UI-driven changes are persisted separately
	# to /var/lib/fdcsds/fdcsds.overrides.json and layered on top.
	cp debian/fdcsds.config.json debian/fdcsds/etc/fdcsds/fdcsds.config.json

	# Install default configuration to /etc/fdcplus (system-wide default)
	mkdir -p debian/fdcsds/etc/fdcplus
	cp fdcsds.config.example debian/fdcsds/etc/fdcplus/fdcsds.config

	# Install sample disk images
	mkdir -p debian/fdcsds/usr/share/fdcsds/disks
	if [ -d disks ]; then \
		cp -r disks/* debian/fdcsds/usr/share/fdcsds/disks/ || true; \
	fi

	# Install documentation
	mkdir -p debian/fdcsds/usr/share/doc/fdcsds
	cp README.md debian/fdcsds/usr/share/doc/fdcsds/
	cp CONTRIBUTING.md debian/fdcsds/usr/share/doc/fdcsds/ || true
	cp docs/WEB-INTERFACE.md debian/fdcsds/usr/share/doc/fdcsds/ || true
	cp docs/LAUNCHER.md debian/fdcsds/usr/share/doc/fdcsds/ || true
	cp docs/TROUBLESHOOTING.md debian/fdcsds/usr/share/doc/fdcsds/ || true
	cp AUTHORS debian/fdcsds/usr/share/doc/fdcsds/ || true

	# Create runtime directories
	mkdir -p debian/fdcsds/var/lib/fdcsds
	mkdir -p debian/fdcsds/var/lib/fdcsds/disks
	mkdir -p debian/fdcsds/var/lib/fdcsds/scripts
	mkdir -p debian/fdcsds/var/lib/fdcsds/uploads
	mkdir -p debian/fdcsds/var/lib/fdcsds/cassettes
	mkdir -p debian/fdcsds/var/log/fdcsds

	# Install systemd service file
	mkdir -p debian/fdcsds/usr/lib/systemd/system
	cp debian/fdcsds.service debian/fdcsds/usr/lib/systemd/system/

	# Install default environment file
	mkdir -p debian/fdcsds/etc/default
	cp debian/fdcsds.default debian/fdcsds/etc/default/fdcsds

override_dh_fixperms:
	dh_fixperms
	# Make the main script executable
	chmod +x debian/fdcsds/usr/lib/fdcsds/dist/index.js
	# Set proper permissions for runtime directories
	chmod 755 debian/fdcsds/var/lib/fdcsds
	chmod 755 debian/fdcsds/var/log/fdcsds

override_dh_installsystemd:
	dh_installsystemd --name=fdcsds --no-enable --no-start
