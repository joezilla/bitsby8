#!/bin/bash
set -e

case "$1" in
    install|upgrade)
        # Seed configuration from a legacy fdcsds install BEFORE dpkg
        # unpacks the new conffiles. When a package is installed for the
        # first time and its conffile already exists on disk, dpkg keeps
        # the on-disk file rather than overwriting it — so copying the
        # operator's old config here preserves their edits into the new
        # /etc/bitsby8 location without a conffile prompt.
        if [ ! -e /etc/bitsby8/bitsby8.config.json ] \
           && [ -e /etc/fdcsds/fdcsds.config.json ]; then
            mkdir -p /etc/bitsby8
            cp -p /etc/fdcsds/fdcsds.config.json /etc/bitsby8/bitsby8.config.json
        fi
        if [ ! -e /etc/default/bitsby8 ] && [ -e /etc/default/fdcsds ]; then
            cp -p /etc/default/fdcsds /etc/default/bitsby8
        fi
        ;;

    abort-upgrade)
        # Nothing to do
        ;;

    *)
        echo "preinst called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
